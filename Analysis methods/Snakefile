rule wavelength_cut_band_edges:
    input:
        verified=smk_path(VERIFY_MARKER),
        manifest=smk_path(MANIFEST),
        config=smk_path(SNAKEMAKE_CONFIG),
        code=CODE_FILES
    output:
        band_edges=smk_path(BAND_EDGES_JSON)
    run:
        build_common_band_edges(
            raw_dir=RAW_DIR,
            relative_paths=SCAN_RELATIVE_PATHS,
            interval_nm=float(WAVELENGTH_CUTS["interval_nm"]),
            wavelength_min_nm=optional_float(WAVELENGTH_CUTS.get("wavelength_min_nm")),
            wavelength_max_nm=optional_float(WAVELENGTH_CUTS.get("wavelength_max_nm")),
            out_json=Path(output.band_edges),
        )


rule wavelength_cut_scan:
    input:
        raw=lambda wildcards: smk_path(RAW_DIR / SCAN_BY_KEY[(wildcards.sample, wildcards.scan_id)]),
        band_edges=smk_path(BAND_EDGES_JSON),
        config=smk_path(SNAKEMAKE_CONFIG),
        code=CODE_FILES
    output:
        status=smk_path(STATUS_DIR / "wavelength_cut_scans" / "{sample}" / "{scan_id}.json"),
        scan_dir=directory(smk_path(CUTS_DIR / "{sample}" / "{scan_id}"))
    run:
        relative_path = SCAN_BY_KEY[(wildcards.sample, wildcards.scan_id)]
        run_wavelength_cut_scan(
            raw_dir=RAW_DIR,
            results_dir=RESULTS_DIR,
            relative_path=relative_path,
            band_edges_json=Path(input.band_edges),
            out_subdir=WAVELENGTH_CUTS_OUT_SUBDIR,
            interval_nm=float(WAVELENGTH_CUTS["interval_nm"]),
            range_mode=str(WAVELENGTH_CUTS["range_mode"]),
            wavelength_min_nm=optional_float(WAVELENGTH_CUTS.get("wavelength_min_nm")),
            wavelength_max_nm=optional_float(WAVELENGTH_CUTS.get("wavelength_max_nm")),
            top_edge_crop_rows=int(WAVELENGTH_CUTS["top_edge_crop_rows"]),
            smooth_sigma=float(WAVELENGTH_CUTS["smooth_sigma"]),
            fit_start_ns=optional_float(WAVELENGTH_CUTS.get("fit_start_ns")),
            fit_start_offset_ns=float(WAVELENGTH_CUTS["fit_start_offset_ns"]),
            fit_end_ns=optional_float(WAVELENGTH_CUTS.get("fit_end_ns")),
            end_fraction=float(WAVELENGTH_CUTS["end_fraction"]),
            min_fit_points=int(WAVELENGTH_CUTS["min_fit_points"]),
            min_peak_sigma=float(WAVELENGTH_CUTS["min_peak_sigma"]),
            secondary_peak_height_fraction=float(WAVELENGTH_CUTS["secondary_peak_height_fraction"]),
            secondary_peak_prominence_fraction=float(WAVELENGTH_CUTS["secondary_peak_prominence_fraction"]),
            secondary_peak_noise_sigma=float(WAVELENGTH_CUTS["secondary_peak_noise_sigma"]),
            secondary_peak_min_separation_ns=float(WAVELENGTH_CUTS["secondary_peak_min_separation_ns"]),
            secondary_peak_exclusion_before_ns=float(WAVELENGTH_CUTS["secondary_peak_exclusion_before_ns"]),
            tau_min_ns=float(WAVELENGTH_CUTS["tau_min_ns"]),
            tau_max_ns=float(WAVELENGTH_CUTS["tau_max_ns"]),
            write_fit_curves=bool(WAVELENGTH_CUTS["write_fit_curves"]),
            write_slice_plots=bool(WAVELENGTH_CUTS["write_slice_plots"]),
            status_json=Path(output.status),
        )


rule wavelength_cut_inventory:
    input:
        status=SCAN_STATUS_JSONS,
        scan_dirs=SCAN_OUTPUT_DIRS
    output:
        inventory=smk_path(CUTS_INVENTORY)
    run:
        aggregate_wavelength_cut_inventory(
            scan_status_jsons=[Path(item) for item in input.status],
            inventory_path=Path(output.inventory),
        )


rule wavelength_cut_fit_results:
    input:
        inventory=smk_path(CUTS_INVENTORY),
        code=CODE_FILES
    output:
        inventory=smk_path(FIT_RESULTS_INVENTORY)
    run:
        args = [
            "--results-dir", RESULTS_DIR,
            "--cuts-subdir", WAVELENGTH_FITS["cuts_subdir"],
            "--out-subdir", WAVELENGTH_FITS["out_subdir"],
            "--rise-window", WAVELENGTH_FITS["rise_window"],
            "--decay-window", WAVELENGTH_FITS["decay_window"],
        ]
        run_main("wavelength_cut_fit_results", args)


rule summary_grids:
    input:
        inventory=smk_path(FIT_RESULTS_INVENTORY),
        selections=SELECTION_FILES,
        fiber_names=smk_path(FIBER_NAMES_CONFIG),
        code=CODE_FILES
    output:
        marker=smk_path(SUMMARY_GRIDS_MARKER)
    run:
        args = [
            "--results-dir", RESULTS_DIR,
            "--fit-subdir", WAVELENGTH_FITS["out_subdir"],
            "--out-subdir", SUMMARY_GRIDS["out_subdir"],
            "--selection-dir", SELECTION_DIR,
            "--fiber-names-config", FIBER_NAMES_CONFIG,
        ]
        run_main("wavelength_cut_summary_plots", args)
        marker = Path(output.marker)
        marker.parent.mkdir(parents=True, exist_ok=True)
        marker.write_text("summary grids: OK\n", encoding="utf-8")


