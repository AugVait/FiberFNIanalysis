from __future__ import annotations

import importlib
import sys
from pathlib import Path

configfile: "configs/snakemake.yaml"

METHODS_ROOT = Path(workflow.basedir).resolve()
if str(METHODS_ROOT) not in sys.path:
    sys.path.insert(0, str(METHODS_ROOT))

from lhcb_fibers_analysis.batch_carpet_wavelength_cuts import sample_folder
from lhcb_fibers_analysis.raw_data_manifest import check_manifest
from lhcb_fibers_analysis.workflow_bridge import (
    aggregate_wavelength_cut_inventory,
    build_common_band_edges,
    run_wavelength_cut_scan,
    scan_id,
    selected_img_relative_paths,
)
from lhcb_fibers_analysis.yaml_config import bool_value, read_yaml_mapping, string_value


def smk_path(path: Path) -> str:
    return path.resolve().as_posix()


def resolve_path(value: str | Path) -> Path:
    path = Path(value)
    return path if path.is_absolute() else (METHODS_ROOT / path).resolve()


def config_path(config_root: Path, value: str) -> Path:
    path = Path(value)
    return path if path.is_absolute() else (config_root / path).resolve()


def optional_value(value):
    return None if value is None or value == "" else value


def optional_float(value):
    value = optional_value(value)
    return None if value is None else float(value)


def yaml_files(path: Path) -> list[str]:
    return [smk_path(item) for item in sorted(path.glob("*.yaml"))] if path.exists() else []


def append_optional(args: list[str], name: str, value) -> None:
    if value is not None and value != "":
        args.extend([name, str(value)])


def append_repeated(args: list[str], name: str, values) -> None:
    if values is None or values == "":
        return
    if isinstance(values, str):
        values = [item.strip() for item in values.split(",") if item.strip()]
    for value in values:
        args.extend([name, str(value)])


def run_main(module_name: str, args: list[str]) -> None:
    analysis_module = importlib.import_module(f"lhcb_fibers_analysis.{module_name}")
    result = analysis_module.main([str(arg) for arg in args])
    if result not in {None, 0}:
        raise RuntimeError(f"{module_name} failed with exit code {result}")


RAW_DIR = resolve_path(config.get("raw_dir", "../raw data"))
RESULTS_DIR = resolve_path(config.get("results_dir", "../Analysis results"))
MANIFEST = resolve_path(config.get("manifest", "raw_data_manifest.json"))
RUN_ALL_CONFIG = resolve_path(config.get("run_all_config", "configs/run_all.yaml"))
STATUS_DIR = resolve_path(config.get("workflow_status_dir", "../Analysis results/workflow_status"))
SNAKEMAKE_CONFIG = METHODS_ROOT / "configs" / "snakemake.yaml"

RUN_ALL = read_yaml_mapping(RUN_ALL_CONFIG)
RUN_CONFIG_ROOT = RUN_ALL_CONFIG.parent

CARPETS_CONFIG = config_path(RUN_CONFIG_ROOT, string_value(RUN_ALL, "carpets_config", "carpets.yaml"))
IT_DECAY_CONFIG = config_path(RUN_CONFIG_ROOT, string_value(RUN_ALL, "it_decay_config", "it_decay_fits_10ns.yaml"))
PEAK_CONFIG = config_path(RUN_CONFIG_ROOT, string_value(RUN_ALL, "peak_position_shift_config", "peak_position_shift.yaml"))
PL_CONFIG_DIR = config_path(RUN_CONFIG_ROOT, string_value(RUN_ALL, "pl_config_dir", "pl_spectra"))
FIBER_NAMES_CONFIG = config_path(RUN_CONFIG_ROOT, string_value(RUN_ALL, "fiber_names_config", "fiber_names.yaml"))

CARPETS_SETTINGS = read_yaml_mapping(CARPETS_CONFIG)
IT_SETTINGS = read_yaml_mapping(IT_DECAY_CONFIG)
PEAK_SETTINGS = read_yaml_mapping(PEAK_CONFIG)

CARPET_SCAN_CONFIG_DIR = config_path(CARPETS_CONFIG.parent, string_value(CARPETS_SETTINGS, "scan_config_dir", "carpets"))
IT_TRACE_CONFIG_DIR = config_path(IT_DECAY_CONFIG.parent, string_value(IT_SETTINGS, "trace_config_dir", "it_decay_fits_10ns"))
PEAK_PL_CONFIG_DIR = config_path(PEAK_CONFIG.parent, string_value(PEAK_SETTINGS, "pl_config_dir", "pl_spectra"))

CARPET_INVENTORY = RESULTS_DIR / string_value(CARPETS_SETTINGS, "out_subdir", "carpets") / "carpet_inventory.csv"
PL_NORMALIZED_INVENTORY = RESULTS_DIR / "pl_spectra" / "pl_spectra_inventory.csv"
PL_RAW_INVENTORY = RESULTS_DIR / "pl_spectra_raw" / "pl_spectra_inventory.csv"
PEAK_SHIFT_TABLE = RESULTS_DIR / string_value(PEAK_SETTINGS, "out_subdir", "peak_position_shift") / "peak_position_shift.csv"
IT_DECAY_INVENTORY = RESULTS_DIR / string_value(IT_SETTINGS, "out_subdir", "it_decay_fits_10ns") / "fit_inventory.csv"

WAVELENGTH_CUTS = config["wavelength_cuts"]
WAVELENGTH_FITS = config["wavelength_cut_fit_results"]
SUMMARY_GRIDS = config["summary_grids"]
LEADING_EDGE = config["leading_edge"]
DOUBLE_EXP = config["double_exp"]
DECAY_TAU = config["decay_tau_slice_position"]
DECAY_TAU_10NS = config["decay_tau_slice_position_10ns_only"]

WAVELENGTH_CUTS_OUT_SUBDIR = WAVELENGTH_CUTS["out_subdir"]
CUTS_DIR = RESULTS_DIR / WAVELENGTH_CUTS_OUT_SUBDIR
CUTS_INVENTORY = CUTS_DIR / "inventory.txt"
FIT_RESULTS_DIR = RESULTS_DIR / WAVELENGTH_FITS["out_subdir"]
FIT_RESULTS_INVENTORY = FIT_RESULTS_DIR / "fit_result_inventory.txt"
SUMMARY_GRIDS_MARKER = STATUS_DIR / "summary_grids.done"
LEADING_EDGE_INVENTORY = FIT_RESULTS_DIR / "leading_edge_position_inventory.txt"
DOUBLE_EXP_INVENTORY = FIT_RESULTS_DIR / "double_exp_fit_result_inventory.txt"
DECAY_TAU_AGGREGATE = RESULTS_DIR / DECAY_TAU["out_subdir"] / "aggregated_decay_tau_by_slice.txt"
DECAY_TAU_10NS_AGGREGATE = RESULTS_DIR / DECAY_TAU_10NS["out_subdir"] / "aggregated_decay_tau_by_slice.txt"
VERIFY_MARKER = STATUS_DIR / "verify_raw_data.done"
BAND_EDGES_JSON = STATUS_DIR / "wavelength_cut_band_edges.json"

SELECTION_DIR = resolve_path(WAVELENGTH_FITS["selection_dir"])
SELECTION_FILES = [smk_path(item) for item in sorted(SELECTION_DIR.glob("*_selection.txt"))]

CODE_FILES = [smk_path(item) for item in sorted((METHODS_ROOT / "lhcb_fibers_analysis").glob("*.py"))]
RUN_ALL_INPUTS = [smk_path(RUN_ALL_CONFIG), smk_path(SNAKEMAKE_CONFIG)]

SCAN_RELATIVE_PATHS = selected_img_relative_paths(MANIFEST, WAVELENGTH_CUTS.get("time_windows"))
SCAN_RECORDS = [
    {
        "sample": sample_folder(relative_path),
        "scan_id": scan_id(relative_path),
        "relative_path": relative_path,
    }
    for relative_path in SCAN_RELATIVE_PATHS
]
SCAN_BY_KEY = {
    (record["sample"], record["scan_id"]): record["relative_path"]
    for record in SCAN_RECORDS
}
SCAN_STATUS_JSONS = [
    smk_path(STATUS_DIR / "wavelength_cut_scans" / record["sample"] / f"{record['scan_id']}.json")
    for record in SCAN_RECORDS
]
SCAN_OUTPUT_DIRS = [
    smk_path(CUTS_DIR / record["sample"] / record["scan_id"])
    for record in SCAN_RECORDS
]

CORE_TARGETS = []
if bool_value(RUN_ALL, "run_carpets", True):
    CORE_TARGETS.append(smk_path(CARPET_INVENTORY))
if bool_value(RUN_ALL, "run_pl_normalized", True):
    CORE_TARGETS.append(smk_path(PL_NORMALIZED_INVENTORY))
if bool_value(RUN_ALL, "run_pl_raw", True):
    CORE_TARGETS.append(smk_path(PL_RAW_INVENTORY))
if bool_value(RUN_ALL, "run_peak_position_shift", True):
    CORE_TARGETS.append(smk_path(PEAK_SHIFT_TABLE))
if bool_value(RUN_ALL, "run_it_decay", True):
    CORE_TARGETS.append(smk_path(IT_DECAY_INVENTORY))

ALL_TARGETS = CORE_TARGETS + [
    smk_path(CUTS_INVENTORY),
    smk_path(FIT_RESULTS_INVENTORY),
    smk_path(SUMMARY_GRIDS_MARKER),
    smk_path(LEADING_EDGE_INVENTORY),
    smk_path(DOUBLE_EXP_INVENTORY),
    smk_path(DECAY_TAU_AGGREGATE),
    smk_path(DECAY_TAU_10NS_AGGREGATE),
]


rule all:
    input:
        ALL_TARGETS


rule core_results:
    input:
        CORE_TARGETS


rule wavelength_cut_results:
    input:
        smk_path(CUTS_INVENTORY),
        smk_path(FIT_RESULTS_INVENTORY)


rule double_exp_results:
    input:
        smk_path(DOUBLE_EXP_INVENTORY)


rule verify_raw_data:
    input:
        manifest=smk_path(MANIFEST)
    output:
        marker=smk_path(VERIFY_MARKER)
    run:
        result = check_manifest(RAW_DIR, MANIFEST)
        if not result.ok:
            raise RuntimeError(f"Raw data does not match manifest: {MANIFEST}")
        marker = Path(output.marker)
        marker.parent.mkdir(parents=True, exist_ok=True)
        marker.write_text("raw data check: OK\n", encoding="utf-8")


rule carpets:
    input:
        verified=smk_path(VERIFY_MARKER),
        config=smk_path(CARPETS_CONFIG),
        fiber_names=smk_path(FIBER_NAMES_CONFIG),
        scan_configs=yaml_files(CARPET_SCAN_CONFIG_DIR),
        run_configs=RUN_ALL_INPUTS,
        code=CODE_FILES
    output:
        inventory=smk_path(CARPET_INVENTORY)
    run:
        args = [
            "--raw-dir", RAW_DIR,
            "--results-dir", RESULTS_DIR,
            "--config", CARPETS_CONFIG,
            "--fiber-names-config", FIBER_NAMES_CONFIG,
        ]
        append_repeated(args, "--time-window", string_value(RUN_ALL, "carpet_time_windows", ""))
        run_main("visualize_carpets", args)


rule pl_spectra_normalized:
