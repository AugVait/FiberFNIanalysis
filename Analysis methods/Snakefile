            "--raw-dir", RAW_DIR,
            "--results-dir", RESULTS_DIR,
            "--config-dir", PL_CONFIG_DIR,
            "--fiber-names-config", FIBER_NAMES_CONFIG,
            "--intensity-mode", "normalized",
        ]
        append_optional(args, "--x-min-nm", string_value(RUN_ALL, "pl_x_min_nm", ""))
        append_optional(args, "--x-max-nm", string_value(RUN_ALL, "pl_x_max_nm", ""))
        run_main("plot_pl_spectra", args)


